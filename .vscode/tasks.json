{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup SGDK (Windows)",
      "type": "shell",
      "command": "echo \"Use make setup on macOS/Linux\"",
      "windows": {
        "command": ".\\sgdk.cmd setup"
      },
      "problemMatcher": []
    },
    {
      "label": "Build ROM",
      "type": "shell",
      "command": "./scripts/sgdk-make.sh",
      "windows": {
        "command": ".\\sgdk.cmd build"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run ROM",
      "type": "shell",
      "command": "./scripts/run-rom.sh",
      "windows": {
        "command": ".\\sgdk.cmd run"
      },
      "dependsOn": "Build ROM",
      "problemMatcher": []
    },
    {
      "label": "Test ROM",
      "type": "shell",
      "command": "make test",
      "windows": {
        "command": ".\\sgdk.cmd test"
      },
      "problemMatcher": []
    }
  ]
}
